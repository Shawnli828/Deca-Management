{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "crons": [
    {
      "path": "/api/reelfarm/sync-all",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/museon/sync-all",
      "schedule": "50 1 * * *"
    },
    {
      "path": "/api/growth/sync-db",
      "schedule": "10 2 * * *"
    },
    {
      "path": "/api/growth/sync-dm",
      "schedule": "25 2 * * *"
    },
    {
      "path": "/api/growth/sync-dl",
      "schedule": "40 2 * * *"
    },
    {
      "path": "/api/reports/daily-feishu-auto",
      "schedule": "30 3 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py?path=api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}
