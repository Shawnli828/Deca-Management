{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "crons": [
    {
      "path": "/api/reelfarm/sync-all",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/museon/sync-all",
      "schedule": "5 2 * * *"
    },
    {
      "path": "/api/growth/sync-all",
      "schedule": "20 2 * * *"
    },
    {
      "path": "/api/reports/daily-feishu-auto",
      "schedule": "0 3 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py?path=api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}
